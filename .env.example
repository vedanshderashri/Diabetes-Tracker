# MedAI Assistant - Environment Configuration
# Copy this file to .env and fill in your values

# ── App ──
APP_NAME=MedAI Assistant
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Server ──
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ──
# SQLite for development:
DATABASE_URL=sqlite+aiosqlite:///./medai.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://medai:password@localhost:5432/medai_db

# ── JWT ──
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OpenAI ──
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── ChromaDB ──
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=medical_knowledge

# ── File Uploads ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=30

# ── ML Models ──
ML_MODELS_DIR=./ml_models
